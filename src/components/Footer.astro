---
import Container from "./Container.astro";

const { siteSettings } = Astro.props;
const s = siteSettings ?? {};

const brandName = s.brandName ?? "HIBISCUS EXECUTIVE SUITES";
const phone = s.phone ?? "941.275.1998";
const phoneLink = s.phoneLink || `tel:${phone.replace(/[^0-9+]/g, "")}`;
const addressLine1 = s.addressLine1 ?? "Hibiscus Executive Suites, LLC";
const addressLine2 = s.addressLine2 ?? "2501 S. Tamiami Trail, Sarasota";
const addressLine3 = s.addressLine3 ?? "FL 34236";
const copyrightText =
  s.copyrightText ??
  "© 2026 Hibiscus Executive Suites | The Hibiscus Executive Suites trademark and related logos are the property of Hibiscus Companies LLC. Photographs may be representative examples of Hibiscus locations and do not necessarily depict the exact design of the referenced Hibiscus location. Hibiscus Executive Suites reserves the right to make changes to any product. Reference to third party names is for informational purposes only and is not necessarily an endorsement or association of Hibiscus Executive Suites or vice versa.";

const services = [
  { label: "Mail & Phone Services", href: "#" },
  { label: "Professional Reception & Gateway", href: "#" },
  { label: "Dedicated Phone Answering", href: "#" },
  { label: "Assistant & Secretary Support", href: "#" },
  { label: "Signage & Virtual Storefront", href: "#" },
  { label: "Google Business Profile Setup & Optimization", href: "#" },
];

const spaces = [
  { label: "Permanent Offices", href: "#" },
  { label: "Individual Executive Suites", href: "#" },
  { label: "Virtual Office Plans (with mail/phone)", href: "#" },
];

const quickLinks = [
  { label: "Conference & Mediation", href: "#" },
  { label: "Why Choose Us", href: "#" },
  { label: "Pricing", href: "#" },
  { label: "Law firm Synergy Story", href: "#" },
  { label: "Testimonials", href: "#" },
  { label: "Gallery", href: "#" },
  { label: "Book Now", href: "#" },
];

const socials = [
  { label: "YouTube",   href: s.socialYoutube   || "#", src: "/images/youtube.png" },
  { label: "Twitter",   href: s.socialTwitter   || "#", src: "/images/twitter.png" },
  { label: "LinkedIn",  href: s.socialLinkedin  || "#", src: "/images/linkedin.png" },
  { label: "Instagram", href: s.socialInstagram || "#", src: "/images/instagram.png" },
  { label: "Facebook",  href: s.socialFacebook  || "#", src: "/images/facebook.png" },
];

const policyLinks = [
  { label: "Privacy", href: "#" },
  { label: "Terms", href: "#" },
  { label: "Accessibility", href: "#" },
  { label: "Sitemap", href: "#" },
];

const labelClass =
  "text-white uppercase text-[14px] font-semibold tracking-[0.1em] mb-5";
const linkClass =
  "text-white text-[14px] hover:opacity-80 transition-opacity";
---

<footer class="bg-[#144C6A] text-white font-['Open_Sans']">
  <Container class="pt-20 pb-[60px]">

    <!-- Brand block (above the columns) -->
    <div class="text-white uppercase font-light tracking-[0.05em] text-[28px] md:text-[32px] mb-10">
      {brandName}
    </div>

    <!-- 4-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- COLUMN 1: SERVICES -->
      <div>
        <h3 class={labelClass}>SERVICES</h3>
        <ul class="space-y-3">
          {services.map((link) => (
            <li>
              <a href={link.href} class={linkClass}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- COLUMN 2: SPACES -->
      <div>
        <h3 class={labelClass}>SPACES</h3>
        <ul class="space-y-3">
          {spaces.map((link) => (
            <li>
              <a href={link.href} class={linkClass}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- COLUMN 3: QUICK LINKS -->
      <div>
        <h3 class={labelClass}>QUICK LINKS</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class={linkClass}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- COLUMN 4: social icons + policy links (anchored to bottom of column) -->
      <div class="flex flex-col h-full">
        <div class="flex items-center gap-5">
          {socials.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              target="_blank"
              rel="noopener noreferrer"
              class="opacity-90 hover:opacity-100 transition-opacity"
            >
              <img
                src={social.src}
                alt={social.label}
                class="h-[28px] w-auto [filter:brightness(0)_invert(1)]"
                loading="lazy"
              />
            </a>
          ))}
        </div>

        <div class="mt-auto pt-6 flex flex-wrap items-center gap-x-2 gap-y-1 text-white text-[14px]">
          {policyLinks.map((link, i) => (
            <Fragment>
              <a href={link.href} class="hover:opacity-80 transition-opacity">
                {link.label}
              </a>
              {i < policyLinks.length - 1 && (
                <span class="text-white" aria-hidden="true">|</span>
              )}
            </Fragment>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#2D5566] mt-10 pt-[30px] flex flex-col lg:flex-row lg:justify-between gap-6">

      <!-- LEFT: phone + address -->
      <div class="text-[14px] space-y-1 min-w-[300px]">
        <div>
          <a href={phoneLink} class="text-white hover:opacity-80 transition-opacity">
            {phone}
          </a>
        </div>
        {addressLine1 && <div class="text-white">{addressLine1}</div>}
        {addressLine2 && <div class="text-white">{addressLine2}</div>}
        {addressLine3 && <div class="text-white">{addressLine3}</div>}
      </div>

      <!-- RIGHT: long copyright paragraph -->
      <div class="lg:max-w-[65%] text-white text-[12px] md:text-[13px] leading-[1.6]">
        {copyrightText}
      </div>
    </div>
  </Container>
</footer>
