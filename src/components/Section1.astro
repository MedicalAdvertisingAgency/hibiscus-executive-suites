---
import { fetchAPI } from '../lib/wp.js';

const query = `
  query GetHomeSection1 {
    pages(where: { name: "home" }) {
      nodes {
        homeSection1 {
          card1Icon
          card1Heading
          card1Content
          card1Link
          card2Icon
          card2Heading
          card2Content
          card2Link
          card3Icon
          card3Heading
          card3Content
          card3Link
          card4Icon
          card4Heading
          card4Content
          card4Link
        }
      }
    }
  }
`;

let section1 = null;
try {
  console.log('GraphQL URL:', import.meta.env.PUBLIC_WP_GRAPHQL_URL);
  const data = await fetchAPI(query);
  section1 = data?.pages?.nodes?.[0]?.homeSection1;
  console.log('Section1 data:', JSON.stringify(section1));
} catch (e) {
  console.warn('Section1 fetch failed:', e.message);
}

const cards = [
  {
    icon: section1?.card1Icon || '/images/Get-a-Quote.webp',
    heading: section1?.card1Heading || 'Get a quote',
    content: section1?.card1Content || 'Receive personalized pricing and workspace solutions aligned perfectly to your business requirements.',
    link: section1?.card1Link || '/get-a-quote',
  },
  {
    icon: section1?.card2Icon || '/images/Book-a-meeting-room.webp',
    heading: section1?.card2Heading || 'Book a meeting room',
    content: section1?.card2Content || 'Reserve fully equipped meeting rooms ideal for presentations, client meetings, or team collaborations.',
    link: section1?.card2Link || '/book-a-meeting-room',
  },
  {
    icon: section1?.card3Icon || '/images/Book-a-center-tour.webp',
    heading: section1?.card3Heading || 'Book a center tour',
    content: section1?.card3Content || 'Schedule a guided visit and experience our workspace facilities firsthand.',
    link: section1?.card3Link || '/book-a-center-tour',
  },
  {
    icon: section1?.card4Icon || '/images/Buy-a-virtual-office.webp',
    heading: section1?.card4Heading || 'Buy a virtual office',
    content: section1?.card4Content || 'Establish a prestigious business address with professional mail and call-handling services.',
    link: section1?.card4Link || '/buy-a-virtual-office',
  },
];
---

<section class="w-full bg-[#f9f5f0] py-10">
  <div class="max-w-[1440px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {cards.map((card) => (
        <a
          href={card.link}
          class="flex flex-row items-center gap-4 bg-white border border-[#e2ddd8] rounded-lg p-5 hover:shadow-md transition-shadow duration-200 group"
        >
          <div class="flex-shrink-0 w-[70px] h-[70px]">
            <img
              src={card.icon}
              alt={card.heading}
              class="w-[70px] h-[70px] object-contain"
            />
          </div>
          <div class="flex flex-col">
            <h3
              class="text-[16px] leading-[18px] font-[600] text-[#1a1a1a] mb-2 tracking-[-0.5px] group-hover:text-[#3d8f7c] transition-colors duration-200"
              style="font-family: 'Open Sans', sans-serif;"
            >
              {card.heading}
            </h3>
            <p
              class="text-[14px] leading-[20px] font-[500] text-[#666666] tracking-[-0.5px]"
              style="font-family: 'Open Sans', sans-serif;"
            >
              {card.content}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
